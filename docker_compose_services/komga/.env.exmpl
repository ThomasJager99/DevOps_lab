#====================
#       Ports
#====================

KOMGA_PORT=25600

#====================
#       Images
#====================

KOMGA_IMAGE=gotson/komga:latest

#====================
#       Paths
#====================

# Path to manga library
MANGA_PATH=/path/to/media/manga

# Path to Komga configuration
KOMGA_CONFIG=/path/to/app_data/komga/config

#====================
#   Resource limits
#====================

KOMGA_CPUS=1
KOMGA_MEM_LIMIT=1g
